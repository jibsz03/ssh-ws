#!/usr/bin/env python3
import os
import sys
import re

G = "\033[0;32m"
C = "\033[0;36m"
Y = "\033[0;33m"
W = "\033[0;37m"
R = "\033[0;31m"
BG = "\033[1;32m"
BR = "\033[1;31m"
BC = "\033[1;36m"
N = "\033[0m"

def vis_len(s):
    return len(re.sub(r'\033\[[0-9;]*m', '', s))

def cbox(s):
    for ch in "┌┐└┘├┤┬┴┼─│":
        s = s.replace(ch, f"{G}{ch}{N}")
    return s

WIDTH = 50

menu_lines = [
    "",
    f"  {W}1.{N} {BG}Add{N} SSH Account",
    f"  {W}2.{N} {C}List{N} SSH Account",
    f"  {W}3.{N} {Y}Delete{N} SSH Account",
    f"  {W}x.{N} {R}Exit{N}",
    "",
]

def render():
    result = ["┌" + "─" * (WIDTH - 2) + "┐"]
    title = f"{BC}SSH-WS-MANAGER{N}"
    space = WIDTH - vis_len(title) - 4
    left = space // 2
    right = space - left
    result.append("│ " + " " * left + title + " " * right + " │")
    result.append("├" + "─" * (WIDTH - 2) + "┤")
    for line in menu_lines:
        pad = WIDTH - vis_len(line) - 4
        result.append("│ " + line + " " * pad + " │")
    result.append("└" + "─" * (WIDTH - 2) + "┘")
    return cbox("\n".join(result))

SCRIPTS = {
    "1": "/usr/local/bin/addssh",
    "2": "/usr/local/bin/listssh",
    "3": "/usr/local/bin/delssh",
}

while True:
    os.system("clear")
    print(render())
    print()
    ch = input(f"  {Y}Pilih{N} [{BG}1{N}/{C}2{N}/{Y}3{N}/{R}x{N}]: ").strip().lower()

    if ch == "x":
        os.system("clear")
        sys.exit(0)

    if ch not in SCRIPTS:
        input(f"  {BR}Pilihan tidak valid{N}, tekan Enter...")
        continue

    os.system("clear")
    os.system(SCRIPTS[ch])
    print()
    input(f"  {Y}Tekan Enter untuk kembali...{N}")
