#!/usr/bin/env python3
import os
import sys
import json
import subprocess
import re

DATA_DIR = "/etc/ssh-sni"
DATA_FILE = os.path.join(DATA_DIR, "users.json")

G = "\033[0;32m"
C = "\033[0;36m"
Y = "\033[0;33m"
W = "\033[0;37m"
R = "\033[0;31m"
BG = "\033[1;32m"
BR = "\033[1;31m"
BC = "\033[1;36m"
N = "\033[0m"

def clear():
    os.system("clear")

def ensure_data():
    os.makedirs(DATA_DIR, exist_ok=True)
    if not os.path.exists(DATA_FILE):
        with open(DATA_FILE, "w") as f:
            json.dump({}, f)

def load_users():
    ensure_data()
    with open(DATA_FILE) as f:
        return json.load(f)

def save_users(users):
    with open(DATA_FILE, "w") as f:
        json.dump(users, f, indent=2)

def user_exists(username):
    return subprocess.call(["id", username], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL) == 0

def delete_user(username):
    subprocess.run(["userdel", "-r", username], capture_output=True, text=True)
    if user_exists(username):
        subprocess.run(["userdel", username], capture_output=True, text=True)
    if user_exists(username):
        raise RuntimeError(f"{BR}Gagal{N} menghapus user {G}{username}{N}")

def vis_len(s):
    return len(re.sub(r'\033\[[0-9;]*m', '', s))

def cbox(s):
    for ch in "┌┐└┘├┤┬┴┼─│":
        s = s.replace(ch, f"{G}{ch}{N}")
    return s

BW = 46
INNER = BW - 2

def border_box(lines, title=None):
    if not lines:
        return "[ Tidak ada data ]"
    result = ["┌" + "─" * INNER + "┐"]
    if title:
        space = BW - vis_len(title) - 4
        l = space // 2
        r = space - l
        result.append("│ " + " " * l + title + " " * r + " │")
        result.append("├" + "─" * INNER + "┤")
    for line in lines:
        pad = BW - vis_len(line) - 4
        line_fmt = line
        if ": " in line and not line.startswith("\033"):
            label, val = line.split(": ", 1)
            line_fmt = f"{Y}{label}{N}: {W}{val}{N}"
        result.append("│ " + line_fmt + " " * pad + " │")
    result.append("└" + "─" * INNER + "┘")
    return cbox("\n".join(result))

def border_table(headers, rows, title=None):
    col_widths = [3, 10, 10, 10]
    n = len(col_widths)
    total_w = sum(col_widths) + 3 * n + 1
    result = []
    if title:
        result.append("┌" + "─" * (total_w - 2) + "┐")
        space = total_w - vis_len(title) - 4
        l = space // 2
        r = space - l
        result.append("│ " + " " * l + title + " " * r + " │")
        result.append("├" + "┬".join("─" * (w + 2) for w in col_widths) + "┤")
    else:
        result.append("┌" + "┬".join("─" * (w + 2) for w in col_widths) + "┐")
    hdr = "│ " + " │ ".join(f"{C}{h.ljust(col_widths[i])}{N}" for i, h in enumerate(headers)) + " │"
    result.append(hdr)
    result.append("├" + "┼".join("─" * (w + 2) for w in col_widths) + "┤")
    for row in rows:
        cells = " │ ".join(str(c).ljust(col_widths[i]) for i, c in enumerate(row))
        result.append("│ " + f"{W}{cells}{N}" + " │")
    result.append("└" + "┴".join("─" * (w + 2) for w in col_widths) + "┘")
    return cbox("\n".join(result))

def main():

    clear()
    username = None

    if len(sys.argv) >= 2:
        username = sys.argv[1]
    else:
        users = load_users()
        if not users:
            print(f"{R}Tidak ada user SSH{N}")
            sys.exit(1)
        sorted_u = sorted(users.items())
        rows = []
        for i, (uname, data) in enumerate(sorted_u, 1):
            pw = data.get("password", "-")
            exp = data.get("expired", "-")
            rows.append([i, uname, pw, exp])
        print(border_table(["No", "User", "Pass", "Exp"], rows, f"{BC}PILIH USER{N}"))
        print()
        try:
            choice = int(input(" Pilih nomor: "))
            username = sorted_u[choice - 1][0]
        except (ValueError, IndexError):
            print(" {BR}Nomor tidak valid{N}")
            sys.exit(1)

    if not username:
        print(f"{G}Username{N} wajib diisi")
        sys.exit(1)

    if not user_exists(username):
        print(border_box([f"User {G}{username}{N} tidak ditemukan"], f"{BR}GAGAL{N}"))
        sys.exit(1)

    confirm = input(f" Yakin {BR}hapus {G}{username}{N}? (y/N): ").strip().lower()
    if confirm != "y":
        print(border_box(["Dibatalkan"], f"{Y}BATAL{N}"))
        sys.exit(0)

    try:
        delete_user(username)
        users = load_users()
        if username in users:
            del users[username]
            save_users(users)
        print(border_box([f"User {G}{username}{N} berhasil dihapus"], f"{BG}SSH USER DELETED{N}"))
    except Exception as e:
        print(border_box([str(e)], f"{BR}GAGAL{N}"))
        sys.exit(1)

if __name__ == "__main__":
    main()
